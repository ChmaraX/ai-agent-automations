---
import GitHubStarLink from '../GitHubStarLink.astro';
import type { SiteConfig } from '../../data/site';

type Props = {
  site: SiteConfig;
  assessmentPrompt: string;
};

const { site, assessmentPrompt } = Astro.props;
---

<header class="hero">
  <GitHubStarLink class="hero-star-link" />

  <div class="hero-copy">
    <div class="kicker mono">{site.heroKicker}</div>
    <h1 class="title-boxed">
      {site.heroTitlePrefix} <span class="invert">{site.heroTitleAccent}</span> {site.heroTitleSuffix}
    </h1>
    <p class="subtitle">{site.description}</p>

    <div class="agent-strip" aria-label="Works with Codex, Claude, and Cursor">
      <div class="agent-strip-label mono">{site.worksWithLabel}</div>
      <div class="agent-list" role="list">
        {
          site.logos.map((logo) => (
            <span class="agent-logo-wrap" role="listitem">
              <img class:list={['agent-logo', logo.className]} src={logo.src} alt={logo.alt} loading="lazy" />
            </span>
          ))
        }
      </div>
    </div>

    <div class="hero-primary-action">
      <button class="hero-copy-action mono" type="button" data-copy-assessment>
        <svg class="hero-copy-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0zM20 3v4M22 5h-4M4 17v2M5 18H3"
          ></path>
        </svg>
        <span class="hero-copy-label" data-copy-assessment-label>Copy prompt</span>
      </button>
      <p class="hero-copy-support">
        Paste into a project or agent chat to find automations that fit.
      </p>
    </div>
  </div>

  <div class="header-art" aria-hidden="true">
    <video autoplay loop muted playsinline preload="auto">
      <source src={site.heroVideoSrc} type="video/webm" />
    </video>
  </div>
</header>

<script id="assessment-prompt-data" type="application/json" set:html={JSON.stringify(assessmentPrompt)}></script>

<script is:inline>
  (() => {
    const buttons = Array.from(document.querySelectorAll('[data-copy-assessment]')).filter(
      (node) => node instanceof HTMLButtonElement,
    );
    const promptNode = document.getElementById('assessment-prompt-data');
    const promptText = promptNode?.textContent ? JSON.parse(promptNode.textContent) : '';
    if (buttons.length === 0 || !promptText) return;

    const labels = new Map(
      buttons.map((button) => [
        button,
        button.querySelector('[data-copy-assessment-label]'),
      ]),
    );
    const defaultLabels = new Map(
      buttons.map((button) => [
        button,
        labels.get(button)?.textContent ?? 'Copy prompt',
      ]),
    );

    const setLabel = (button, text) => {
      const label = labels.get(button);
      if (label) {
        label.textContent = text;
      }
    };

    const writePrompt = async () => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(promptText);
        return;
      }

      const textarea = document.createElement('textarea');
      textarea.value = promptText;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      textarea.style.pointerEvents = 'none';
      document.body.append(textarea);
      textarea.select();
      const copied = document.execCommand('copy');
      textarea.remove();
      if (!copied) {
        throw new Error('execCommand copy failed');
      }
    };

    for (const button of buttons) {
      button.addEventListener('click', async () => {
        try {
          await writePrompt();
          for (const target of buttons) {
            setLabel(target, 'Copied');
          }
        } catch {
          for (const target of buttons) {
            setLabel(target, 'Copy failed');
          }
        }

        window.setTimeout(() => {
          for (const target of buttons) {
            setLabel(target, defaultLabels.get(target) ?? 'Copy prompt');
          }
        }, 1600);
      });
    }
  })();
</script>
